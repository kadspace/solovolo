{
  "name": "solovolo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check src/worker.js",
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create solovolo",
    "d1:migrate:local": "wrangler d1 migrations apply solovolo --local",
    "d1:migrate:remote": "wrangler d1 migrations apply solovolo --remote"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
