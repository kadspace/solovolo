# Discord webhook URL for notifications
# Get this from Discord: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# How often to check for new activities (in seconds)
# Default: 300 (5 minutes)
POLL_INTERVAL=300

# Comma-separated sports to suppress from Discord pings
# Default: Softball
EXCLUDED_SPORTS=Softball

# Comma-separated sports to check; leave blank to check all sports
WATCHED_SPORTS=

# Set false if you do not want current activities pinged on process startup
NOTIFY_ON_STARTUP=true

# Set false if you do not want an "online" ping whenever the worker boots
SEND_STARTUP_STATUS=true
